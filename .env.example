# Rename this file to .env and fill in your values

# Database (Render provides PostgreSQL URL)
DATABASE_URL=sqlite:///./test.db

# Stripe - get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Site URLs
SITE_URL=https://9zkjrqsrm2-code.github.io/seven-quotients-test
BACKEND_URL=https://your-app.onrender.com

# Admin login (SHA-256 of password)
# Leave empty to use default: admin / admin123
ADMIN_PASSWORD_HASH=

SECRET_KEY=change-this-to-a-random-string
PAID_PRICE_CNY=2999
